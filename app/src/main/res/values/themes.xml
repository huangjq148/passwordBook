<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- ============================================
         PasswordSafe - OLED Security Dashboard Theme
         Midnight slate + emerald trust + cyan highlights
         ============================================ -->
    
    <!-- Base Application Theme - Dark -->
    <style name="Theme.PasswordSafe" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary Brand Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_inverse</item>
        
        <!-- Secondary Brand Colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/text_inverse</item>
        
        <!-- Accent Colors -->
        <item name="colorAccent">@color/accent</item>
        
        <!-- Background Colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/background_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- Window Background -->
        <item name="android:windowBackground">@color/background</item>
        
        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        
        <!-- Action Bar (if needed) -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        
        <!-- Ripple Effect -->
        <item name="colorControlHighlight">@color/primary_20</item>
    </style>
    
    <!-- Card Style -->
    <style name="Widget.PasswordSafe.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
    </style>
    
    <!-- Elevated Card Style -->
    <style name="Widget.PasswordSafe.Card.Elevated" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">8dp</item>
        <item name="rippleColor">@color/primary_20</item>
    </style>
    
    <!-- Button Styles -->
    <style name="Widget.PasswordSafe.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
    
    <style name="Widget.PasswordSafe.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>
    
    <!-- Input Field Style -->
    <style name="Widget.PasswordSafe.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/secondary</item>
        <item name="boxBackgroundColor">@color/background_surface</item>
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>
    
    <!-- Title Text Style -->
    <style name="TextAppearance.PasswordSafe.Title" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>
    
    <!-- Subtitle Text Style -->
    <style name="TextAppearance.PasswordSafe.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>
    
    <!-- Body Text Style -->
    <style name="TextAppearance.PasswordSafe.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <!-- Caption Text Style -->
    <style name="TextAppearance.PasswordSafe.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="TextAppearance.PasswordSafe.BottomNav.Active" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.PasswordSafe.BottomNav.Inactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
    </style>
    
    <!-- Chip Style -->
    <style name="Widget.PasswordSafe.Chip" parent="Widget.MaterialComponents.Chip.Action">
        <item name="chipBackgroundColor">@color/background_elevated</item>
        <item name="chipStrokeColor">@color/border</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="chipCornerRadius">20dp</item>
    </style>
    
    <!-- Chip Filter Style -->
    <style name="Widget.PasswordSafe.Chip.Filter" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/background_elevated</item>
        <item name="chipStrokeColor">@color/border</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="checkedIconVisible">false</item>
    </style>
    
    <!-- FAB Style -->
    <style name="Widget.PasswordSafe.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/text_inverse</item>
        <item name="fabSize">normal</item>
        <item name="rippleColor">@color/accent_light</item>
    </style>
    
    <!-- Bottom Navigation Style -->
    <style name="Widget.PasswordSafe.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/background_card</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="itemRippleColor">@color/primary_20</item>
    </style>

    <style name="Widget.PasswordSafe.BottomNavTab" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">56dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:background">@drawable/bg_nav_tab</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/nav_tab_text_color</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="cornerRadius">24dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">10dp</item>
        <item name="iconTint">@color/nav_tab_text_color</item>
        <item name="rippleColor">@color/primary_20</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:gravity">center</item>
        <item name="iconSize">20dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="elevation">0dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    
    <!-- Toolbar Style -->
    <style name="Widget.PasswordSafe.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/background</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="navigationIconTint">@color/text_primary</item>
    </style>
    
    <!-- Switch Style -->
    <style name="Widget.PasswordSafe.Switch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="thumbTint">@color/switch_thumb</item>
        <item name="trackTint">@color/switch_track</item>
    </style>
</resources>
